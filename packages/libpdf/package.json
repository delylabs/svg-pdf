{
    "name": "@svg-pdf/libpdf",
    "version": "0.1.1",
    "description": "SVG to real PDF vectors, embedded via @libpdf/core",
    "keywords": [
        "svg",
        "pdf",
        "typescript",
        "web-worker",
        "vector-graphics",
        "pdf-generation",
        "svg-to-pdf"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/delylabs/svg-pdf.git",
        "directory": "packages/libpdf"
    },
    "homepage": "https://github.com/delylabs/svg-pdf#readme",
    "bugs": {
        "url": "https://github.com/delylabs/svg-pdf/issues"
    },
    "type": "module",
    "publishConfig": {
        "access": "public"
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsdown"
    },
    "dependencies": {
        "@svg-pdf/core": "^0.1.0"
    },
    "peerDependencies": {
        "@libpdf/core": "^0.4.1"
    },
    "devDependencies": {
        "@libpdf/core": "^0.4.1"
    }
}
