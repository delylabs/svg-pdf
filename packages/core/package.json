{
    "name": "@svg-pdf/core",
    "version": "0.1.1",
    "description": "SVG to real PDF vectors — not locked to one PDF library",
    "keywords": [
        "svg",
        "pdf",
        "typescript",
        "web-worker",
        "vector-graphics",
        "pdf-generation",
        "svg-to-pdf"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/delylabs/svg-pdf.git",
        "directory": "packages/core"
    },
    "homepage": "https://github.com/delylabs/svg-pdf#readme",
    "bugs": {
        "url": "https://github.com/delylabs/svg-pdf/issues"
    },
    "type": "module",
    "publishConfig": {
        "access": "public"
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "unpkg": "./dist/index.global.iife.js",
    "jsdelivr": "./dist/index.global.iife.js",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsdown"
    },
    "dependencies": {
        "@xmldom/xmldom": "^0.9.10",
        "css-select": "^7.0.0",
        "css-what": "^8.0.0"
    }
}
