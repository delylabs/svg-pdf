#!/usr/bin/env node
import fs from 'fs';

const TYPES = ['feat', 'fix', 'docs', 'style', 'refactor', 'test', 'chore'];
const HEADER_RE = new RegExp(`^(${TYPES.join('|')}): .+`);

const messagePath = process.argv[2];
const rawLines = fs.readFileSync(messagePath, 'utf8').split('\n');
const lines = rawLines.filter((line) => !line.startsWith('#'));
while (lines.length > 0 && lines[lines.length - 1] === '') lines.pop();

const errors = [];
const header = lines[0] ?? '';

if (!HEADER_RE.test(header)) {
    errors.push(
        `Header must match "<type>: <subject>" with type one of: ${TYPES.join(', ')}.\n  Got: "${header}"`,
    );
}

const body = lines.slice(1);
if (body.length > 0 && body[0] !== '') {
    errors.push('Header and body must be separated by exactly one blank line.');
}

if (errors.length > 0) {
    console.error('\nCommit message rejected:\n');
    for (const error of errors) console.error(`  - ${error}`);
    console.error('');
    process.exit(1);
}
